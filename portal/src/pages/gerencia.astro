---
import { getClientes, getFocos, getPdfs, getObjetivos, getFacturacion } from '../lib/data';
import { getConfig } from '../lib/config';
import GerenciaDashboard from '../components/GerenciaDashboard';

const role = Astro.cookies.get('orbit_role')?.value;
if (role !== 'gerencia') return Astro.redirect('/');

const clientes    = await getClientes();
const focos       = await getFocos();
const pdfs        = await getPdfs();
const objetivos   = await getObjetivos();
const facturacion = await getFacturacion();
const cfg         = getConfig();
const vendorNames = cfg.vendor_names;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orbit · Gerencia</title>
    <link rel="stylesheet" href="/orbit.css" />
    <link rel="icon" href="/assets/orbit-mark.png" type="image/png" />
  </head>
  <body>
    <div class="bg-grid"></div>
    <GerenciaDashboard
      client:load
      clientes={clientes}
      focos={focos}
      pdfs={pdfs}
      vendorNames={vendorNames}
      objetivos={objetivos}
      facturacion={facturacion}
    />
    <script src="/audio.js" is:inline></script>
  </body>
</html>
