---
import { getConfig } from '../lib/config';
import Login from '../components/Login';

const cfg = getConfig();
const hasError = Astro.url.searchParams.get('error') === '1';

const profiles = [
  { id: 'gerencia', label: 'Gerencia', sub: 'PyP Logística', tag: 'MT' },
  ...Object.entries(cfg.vendor_names).map(([id, name]) => ({
    id,
    label: name,
    sub: `Vendedor ${id}`,
    tag: name.slice(0, 2).toUpperCase(),
  })),
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orbit · Tienda Perfecta</title>
    <link rel="stylesheet" href="/orbit.css" />
    <link rel="icon" href="/assets/orbit-mark.png" type="image/png" />
  </head>
  <body>
    <div class="bg-grid"></div>
    <Login client:load profiles={profiles} initialError={hasError} />
    <script src="/audio.js" is:inline></script>
  </body>
</html>
